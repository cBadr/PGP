# ─── Database (PostgreSQL) ────────────────────────────────────────────
# Recommended: Neon (https://neon.tech) — free serverless Postgres.
# Or use Vercel Postgres / Supabase / a local Docker postgres.
#
# Format:
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth.js ──────────────────────────────────────────────────────────
# Generate a strong secret:
#   npx auth secret
# (or any 32+ char random string)
AUTH_SECRET="replace-with-a-long-random-string"

# Required on Vercel and other serverless hosts behind a proxy.
AUTH_TRUST_HOST=true
