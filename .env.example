# ─── Database (PostgreSQL) ────────────────────────────────────────────
#
# DATABASE_URL — used at RUNTIME by the pg driver adapter.
#   On Supabase: use the TRANSACTION pooler URL (port 6543).
#   This is the only pooler that scales to many concurrent
#   short-lived Vercel serverless invocations.
#
# DIRECT_URL — used by `prisma migrate` and `prisma db push`.
#   On Supabase: use the SESSION pooler URL (port 5432).
#   Migrations need prepared statements; transaction mode doesn't support them.
#
# Get both from Supabase → Connect → switch the "Mode" dropdown.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Auth.js ──────────────────────────────────────────────────────────
# Generate a strong secret:
#   npx auth secret
# (or any 32+ char random string)
AUTH_SECRET="replace-with-a-long-random-string"

# Required on Vercel and other serverless hosts behind a proxy.
AUTH_TRUST_HOST=true
